# AI providers
# VOICE_BACKEND=managed   → Deepgram + Fish (no GPU)
# VOICE_BACKEND=chatterbox → Whisper + Chatterbox Turbo on GPU (recommended)
# VOICE_BACKEND=gpu        → Whisper + Piper (legacy, less human)
VOICE_BACKEND=chatterbox

DEEPGRAM_API_KEY=
GOOGLE_API_KEY=
FISH_AUDIO_API_KEY=

# Fish Audio voice/model (managed backend only)
FISH_AUDIO_MODEL=s1
FISH_AUDIO_REFERENCE_ID=

# GPU backend — faster-whisper STT (pip install "pipecat-ai[whisper]")
WHISPER_MODEL=distil-large-v2
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8_float16

# Chatterbox Turbo (VOICE_BACKEND=chatterbox) — free zero-shot clone from WAV
CHATTERBOX_REFERENCE_AUDIO=
CHATTERBOX_DEVICE=cuda
CHATTERBOX_EXAGGERATION=0.35
CHATTERBOX_CFG_WEIGHT=0.5

# Speech renderer (all FSM + Gemini + KB replies before TTS)
SPEECH_MAX_WORDS=14
SPEECH_PAUSE_MIN_MS=400
SPEECH_PAUSE_MAX_MS=700

# Piper (VOICE_BACKEND=gpu only)
# Leave PIPER_EXE empty to auto-detect agent/piper/piper.exe
PIPER_EXE=
PIPER_MODEL=
PIPER_SPEAKER=0

# LLM
GEMINI_MODEL=gemini-2.5-flash-lite

# ViciDial (the BPO's dialer)
VICIDIAL_BASE_URL=https://dialer.example.com
VICIDIAL_API_USER=
VICIDIAL_API_PASS=
# Closer group / preset the warm transfer should land on
VICIDIAL_TRANSFER_PRESET=CLOSER

# Where the bot's media socket listens (wired to ViciDial/SIP media)
AGENT_HOST=0.0.0.0
AGENT_PORT=8765

# Supabase — load scripts saved in the dashboard (service role, keep secret)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Browser WebRTC call (no Twilio) — set when exposing Vast via ngrok for phone testing
# LOCAL_SERVER_URL=https://xxxx.ngrok-free.app

# Phone test (Twilio PSTN — real calls without ViciDial)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
# Public HTTPS URL from ngrok / cloudflare tunnel (Twilio cannot hit localhost)
LOCAL_SERVER_URL=https://xxxx.ngrok-free.app
