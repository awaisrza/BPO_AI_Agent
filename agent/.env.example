# AI providers
DEEPGRAM_API_KEY=
GOOGLE_API_KEY=
FISH_AUDIO_API_KEY=

# Fish Audio voice/model
FISH_AUDIO_MODEL=s1
FISH_AUDIO_REFERENCE_ID=

# Piper (local TTS — scripts/test_piper.py)
# Leave PIPER_EXE empty to auto-detect agent/piper/piper.exe
PIPER_EXE=
PIPER_MODEL=
PIPER_SPEAKER=0

# LLM
GEMINI_MODEL=gemini-2.5-flash-lite

# ViciDial (the BPO's dialer)
VICIDIAL_BASE_URL=https://dialer.example.com
VICIDIAL_API_USER=
VICIDIAL_API_PASS=
# Closer group / preset the warm transfer should land on
VICIDIAL_TRANSFER_PRESET=CLOSER

# Where the bot's media socket listens (wired to ViciDial/SIP media)
AGENT_HOST=0.0.0.0
AGENT_PORT=8765

# Supabase — load scripts saved in the dashboard (service role, keep secret)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Phone test (Twilio PSTN — real calls without ViciDial)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
# Public HTTPS URL from ngrok / cloudflare tunnel (Twilio cannot hit localhost)
LOCAL_SERVER_URL=https://xxxx.ngrok-free.app
